olor\" stroke-width=\"0\" transform=\"matrix(1 0 0 -1 0 0)\" aria-hidden=\"true\">\n <use xlink:href=\"#E1-MJMATHI-4F\" x=\"0\" y=\"0\"></use>\n <use xlink:href=\"#E1-MJMAIN-28\" x=\"763\" y=\"0\"></use>\n <use xlink:href=\"#E1-MJMATHI-6D\" x=\"1153\" y=\"0\"></use>\n <use xlink:href=\"#E1-MJMAIN-2B\" x=\"2253\" y=\"0\"></use>\n <use xlink:href=\"#E1-MJMATHI-6E\" x=\"3254\" y=\"0\"></use>\n <use xlink:href=\"#E1-MJMAIN-29\" x=\"3854\" y=\"0\"></use>\n</g>\n</svg></p>\n<pre class=\"line-numbers language-python\" data-language=\"python\"><code class=\"language-python\">class Solution:\n    def findMedianSortedArrays(self, nums1: List[int], nums2: List[int]) -&gt; float:\n        arr &#x3D; []\n        n &#x3D; len(nums1)\n        m &#x3D; len(nums2)\n        i &#x3D; j &#x3D; 0\n        t &#x3D; int((m + n) &#x2F; 2)\n        while(i + j &lt;&#x3D; t):\n            if i &#x3D;&#x3D; n and j !&#x3D; m:\n                arr.append(nums2[j])\n                j +&#x3D; 1\n                continue\n            elif i !&#x3D; n and j &#x3D;&#x3D; m:\n                arr.append(nums1[i])\n                i +&#x3D; 1\n                continue\n            if nums1[i] &lt; nums2[j]:\n                arr.append(nums1[i])\n                i +&#x3D; 1\n            else:\n                arr.append(nums2[j])\n                j +&#x3D; 1\n\n        if (m + n) % 2 &#x3D;&#x3D; 0:\n            return float((arr[t] + arr[t - 1]) &#x2F; 2)\n        return float(arr[t])</code></pre>\n\n","text":"寻找两个正序数组的中位数给定两个大小分别为 m 和 n 的正序（从小到大）数组 nums1 和 nums2。请你找出并返回这两个正序数组的 中位数 示例 1： 输入：nums1 = [1,3], nums2 = [2]输出：2.00000解释：合并数组 = [1,2,3] ，中位...","link":"","photos":[],"count_time":{"symbolsCount":"2k","symbolsTime":"2 mins."},"categories":[{"name":"刷题","slug":"刷题","count":5,"path":"api/categories/刷题.json"},{"name":"Leecode","slug":"刷题/Leecode","count":5,"path":"api/categories/刷题/Leecode.json"}],"tags":[{"name":"Leecode","slug":"Leecode","count":6,"path":"api/tags/Leecode.json"}],"toc":"<ol class